# GitaVerse — Environment Variables Template
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=3000

# ── ElevenLabs TTS (most human-like audio, 10K chars/month free) ──
# Get key: https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=
# Voice IDs from https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB       # Default: "Adam" — deep, calm
ELEVENLABS_VOICE_MALE=pNInz6obpgDQGcFmaJgB     # Legacy compat
ELEVENLABS_VOICE_FEMALE=EXAVITQu4vr4xnSDxMaL   # Legacy compat

# ── Anthropic Claude (Saarathi AI guide) ─────────────────────
# Get key: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Google Cloud TTS (optional, higher quality Sanskrit) ──────
# Get key: https://console.cloud.google.com → Cloud Text-to-Speech API
GOOGLE_TTS_API_KEY=
